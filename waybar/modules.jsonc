{
  "hyprland/window": {
    "format": "{title}",
    "max-length": 25,
    "separate-outputs": false,
    "icon": false,
    "rewrite": {
      "(.*) â€” Mozilla Firefox": "َ°ˆ¹ Firefox",
      "Mozilla Firefox": "َ°ˆ¹ Firefox",
      "Discord": "ï‡؟ Vesktop",
      "Spotify Premium": "ï†¼ Spotify",
      "^.*(Code - OSS)$": "َ°¨‍ VSCode",
      "^.*v( .*|$)": "ïچ¯ Neovim",
      "^.*~$": "َ°„› Kitty",
      "(.*) - Obsidian v(.*)": "ï€؛ Obsidian",
      "": "î«¤ Empty"      
    }
  },

  "hyprland/workspaces": {
    "format": "{icon}",
    "on-click": "activate",
    "all-outputs": false,
    "format-icons": {
      //"1": "1",
      //"2": "2",
      //"3": "3",
      //"4": "4",
      "5": "َ°““",
      "11": "ï‡؟",
      "12": "ï†¼",
      //"13": "3",
      //"14": "4",
      //"15": "5",
      "urgent": "ïپھ",
      "focused": "ï†’",
      "default": "î©±"
    },
    "persistent-workspaces": {
      "DP-1": [1, 2, 3, 4, 5],
      "DP-2": [11, 12, 13, 14, 15]
    }
  },
  
  "group/info": {
    "orientation": "inherit",
    "drawer": { "transition-duration": 300, "transition-left-to-right": false },
    "modules": ["custom/arrow-right", "cpu", "memory", "disk"]
  },
    
  "custom/arrow-right": { "format": "ï“ƒ", "tooltip": false },
  "cpu": { "format": "َ°کڑ {usage}َ±‰¸" },
  "memory": { "format": "ïˆ€ {:2}َ±‰¸" },
  "disk": { "interval": 600, "format": "َ°†¼ {percentage_used}َ±‰¸", "path": "/" },

  "group/cc": {
    "orientation": "inherit",
    "modules": ["group/connection", "group/audio", "group/power", "custom/notifications"]
  },

  "group/connection": {
    "orientation": "inherit",
    "drawer": { "transition-duration": 300, "transition-left-to-right": false },
    "modules": ["network", "group/bt", "network#speed" ]
  },

  "network": {
    "format": "{icon}",
    "format-icons": { "wifi": ["َ°¤¨"], "ethernet": ["َ°ˆ€"], "disconnected": ["î«گ"] },
    "format-wifi": "ïگ¨",
    "format-ethernet": "َ°ˆ€",
    "format-disconnected": "î«گ"
  },

  "network#speed": {
    "format": "ï€™ {bandwidthDownBits} ï‚“ {bandwidthUpBits}",
    "interval": 3
  },

  "group/bt": {
    "orientation": "inherit",
    "drawer": { "transition-duration": 300, "transition-left-to-right": true },
    "modules": ["bluetooth", "bluetooth#status"]
  },

  "bluetooth": {
    "format-on": "َ°‚¯",
    "format-off": "َ°‚²",
    "format-connected": "ï‘Œ",
    "on-click": "overskride"
  },

  "bluetooth#status": {
    "format-connected": "<b>{num_connections}</b>",
    "format-connected-battery": "<small><b>{device_battery_percentage}%</b></small>"
  },

  "group/audio": {
    "orientation": "inherit",
    "drawer": { "transition-duration": 300, "transition-left-to-right": false },
    "modules": ["pulseaudio", "pulseaudio#mic"]
  },

  "pulseaudio": {
      "format": "{icon}",
      "format-muted": "ï‘¦",
      "on-click": "pavucontrol -t 3",
      "format-icons": { "default": ["ï‘¦","ï’…", "ï’…", "ï’…"] }
  },

  "pulseaudio#mic": {
      "format": "{format_source}",
      "format-source": "َ°چ°",
      "format-source-muted": "َ°چ±",
      "on-click": "pavucontrol -t 4"
  },

  "group/utils": {
    "orientation": "inherit",
    "drawer": { "transition-duration": 300, "transition-left-to-right": true },
    "modules": ["custom/arrow-left", "tray", "backlight"]
  },
    
  "custom/arrow-left": { "format": "ï“ƒ", "tooltip": false },
  "tray": { "spacing": 5, "icon-size": 20 },

  "backlight": {
    "device": "intel_backlight",
    "format": "{icon}",
    "format-icons": ["îژچ", "îڈ“", "îڈ‘", "îڈڈ", "îڈژ", "îڈچ", "îڈٹ", "îڈˆ", "îژ›"]
  },

  "custom/notifications": {
    "format": "{icon}",
    "format-icons": { "notification": "َ±…«", "none": "َ°‚ڑ", "dnd-notification": "َ°‚›" },
    "return-type": "json",
    "exec": "swaync-client -swb",
    "on-click": "swaync-client -t -sw"
  },

  "group/power": {
    "orientation": "inherit",
    "drawer": { "transition-duration": 300, "transition-left-to-right": false },
    "modules": ["battery", "power-profiles-daemon"]
  },

  "battery": {
      "states": { "warning": 30, "critical": 20 },
      "format": "{icon}",
      "format-icons": ["ï‰„", "ï‰ƒ", "ï‰‚", "ï‰پ", "ï‰€"]
  },

  "power-profiles-daemon": {
    "format": "{icon}",
    "format-icons": { "default": "ïƒ§", "performance": "ïƒ§", "balanced": "ï‰ژ", "power-saver": "ïپ¬" }
  },

  "custom/home": {
      "format": "ïگژ{}",
      "on-click": "wofi",
      "on-click-right": "poweroff"
  },

  "group/time": {
      "orientation": "inherit",
      "modules": ["idle_inhibitor", "clock"]
  },

  "clock": {
      "format": "{:%R   ï‘• %dآ·%mآ·%y}",
      "tooltip-format": "<tt>{calendar}</tt>"
  },

  "idle_inhibitor": {
      "format": "{icon}",
      "format-icons": { "activated": "ïگ؛", "deactivated": "ïگ؛" }
  },

  "mpris": {
	"format": "{player_icon} {artist} - {title}",
	"player-icons": { "default": "ï‘©", "mpv": "ًںژµ" },
	"status-icons": { "paused": "ïگ—" }
  }
}